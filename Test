function checkWorkflowIfLocked() {
    if (!Granite.author || !Granite.author.ContentFrame) return;
    var pagePath = Granite.author.ContentFrame.getContentPath();
    if (!pagePath) return;

    // Get the iframe's jQuery
    var $iframe = Granite.author.ContentFrame.getContentFrame();
    var iframeDoc = $iframe[0].contentDocument || $iframe[0].contentWindow.document;
    var $$ = $(iframeDoc);

    // Listen on iframe document
    $$(iframeDoc).off("click.workflowLock")
        .on("click.workflowLock", ".cq-dialog-submit", function (e) {
            e.stopImmediatePropagation();
            e.preventDefault();

            $.getJSON(pagePath + "/jcr:content.json").done(function (data) {
                if (data["jcr:lockOwner"]) {
                    // Close dialog in iframe
                    $$(iframeDoc).find("coral-dialog[open]").each(function() {
                        this.hide();
                    });
                    showLockAlert(data["jcr:lockOwner"]);
                } else {
                    // Not locked - re-trigger
                    $$(iframeDoc).find(".cq-dialog-submit")
                        .off("click.workflowLock")[0].click();
                }
            }).fail(function () {
                $$(iframeDoc).find(".cq-dialog-submit")
                    .off("click.workflowLock")[0].click();
            });
        });
}
