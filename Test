_buildMpcCodeReferences = function (data) {
  var mpcCodes = (data.mpcCodes && data.mpcCodes instanceof Array) ? data.mpcCodes : [];

  var btns = "";
  mpcCodes.forEach(function (code) {
    btns += "<button class='viewMpcCodeDetailsBtn' onclick='event.stopPropagation();'>" + code + "</button>";
  });

  return ""
    + "<div class='mpcWrap'>"
    + "  <div class='mpcRowInner'>" + btns + "</div>"
    + "  <span class='mpcDots'>&hellip;</span>"
    + "  <div class='mpcTooltip'></div>"
    + "</div>";
};

.mpcWrap {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
}

.mpcRowInner {
  display: flex;
  flex-wrap: nowrap;
  gap: 4px;
  overflow: hidden;   // clips extra buttons
  min-width: 0;       // IMPORTANT
  flex: 1 1 auto;
}

.mpcDots {
  display: none;      // shown only when overflow
  padding-left: 6px;
}

.mpcWrap.hasOverflow .mpcDots {
  display: inline-block;
}

/* tooltip */
.mpcTooltip {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  margin-top: 6px;
  z-index: 9999;
  padding: 8px;
  background: #fff;
  border: 1px solid #ccc;
  box-shadow: 0 2px 10px rgba(0,0,0,.15);

  /* make tooltip buttons wrap nicely */
  max-width: 450px;
  white-space: normal;
}
.mpcWrap.showTooltip .mpcTooltip {
  display: block;
}


function initMpcEllipsisAndTooltip() {

  document.querySelectorAll(".mpcWrap").forEach(function (wrap) {

    var inner = wrap.querySelector(".mpcRowInner");
    var tooltip = wrap.querySelector(".mpcTooltip");

    if(!inner || !tooltip) return;

    // check overflow
    var overflowing = inner.scrollWidth > inner.clientWidth;

    if (overflowing) {
      wrap.classList.add("hasOverflow");
    }

    // tooltip content
    tooltip.innerHTML = inner.innerHTML;

    // hover behaviour
    wrap.onmouseenter = function () {
      if (wrap.classList.contains("hasOverflow")) {
        wrap.classList.add("showTooltip");
      }
    };

    wrap.onmouseleave = function () {
      wrap.classList.remove("showTooltip");
    };

  });

}


$('#OfferProductTable').on('draw.dt', function () {
    initMpcEllipsisAndTooltip();
});
