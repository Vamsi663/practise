.mpcContainer{
    position:relative;
    display:flex;
    align-items:center;
    width:100%;
}

.mpcRow{
    display:flex;
    flex-wrap:nowrap;
    overflow:hidden;
    gap:6px;
    flex:1;
}

.mpcRow .viewMpcCodeDetailsBtn{
    flex:0 0 auto;
}

.mpcEllipsis{
    display:block;
    cursor:pointer;
    margin-left:5px;
}

/* tooltip */

.mpcTooltip{
    display:none;
    position:absolute;
    top:0;
    left:100%;
    margin-left:10px;
    padding:10px;

    background:#fff;
    border:1px solid #ccc;
    box-shadow:0 2px 8px rgba(0,0,0,.2);

    max-width:450px;
    white-space:normal;
}

.mpcEllipsis:hover + .mpcTooltip,
.mpcTooltip:hover{
    display:block;
}
