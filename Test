private USCBCarouselImpl createCarouselModel(Map<String, Object> props) {
    Map<String, Object> allProps = new HashMap<>(props);
    allProps.put("sling:resourceType", RESOURCE_TYPE);

    carouselResource = context.create().resource(
            "/content/test-page/jcr:content/carousel", allProps);

    context.currentResource(carouselResource);
    context.request().setResource(carouselResource);

    context.registerAdapter(
            org.apache.sling.api.SlingHttpServletRequest.class,
            com.adobe.cq.wcm.core.components.models.Carousel.class,
            (java.util.function.Function<org.apache.sling.api.SlingHttpServletRequest, com.adobe.cq.wcm.core.components.models.Carousel>)
                    request -> /* use IntelliJ Alt+Enter "Implement methods" here to fill in real signatures */ null
    );

    return context.request().adaptTo(USCBCarouselImpl.class);
}
