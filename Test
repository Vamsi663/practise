_buildMpcCodeReferences = function (data) {
    var mpcCodes = (data.mpcCodes && data.mpcCodes instanceof Array) ? data.mpcCodes : [];

    function esc(s) {
        return (s == null) ? "" : String(s)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
    }

    function link(code) {
        // keep your existing click handler class
        return "<a href='#' class='viewMpcCodeDetailsBtn mpcLink'>" + esc(code) + "</a>";
    }

    if (!mpcCodes.length) {
        return "";
    }

    var visibleHtml = mpcCodes.slice(0, 2).map(link).join("");
    var allHtml = mpcCodes.map(link).join("");
    var hasMore = mpcCodes.length > 2;

    return ""
        + "<div class='mpcCell'>"
        + "  <div class='mpcVisible'>" + visibleHtml + "</div>"
        + (hasMore ? "  <span class='mpcEllipsis' tabindex='0' aria-label='Show all MPC codes'>&hellip;</span>" : "")
        + (hasMore ? "  <div class='mpcTooltip'>" + allHtml + "</div>" : "")
        + "</div>";
};


.mpcCell:hover .mpcTooltip { display:block; }


/* tooltip default hidden */
.mpcTooltip { display: none; }

/* show tooltip ONLY when hovering ellipsis OR tooltip itself */
.mpcEllipsis:hover + .mpcTooltip,
.mpcEllipsis:focus + .mpcTooltip,
.mpcTooltip:hover {
    display: block;
}



.mpcTooltip {
    display: none;
    position: absolute;
    top: 18px;        /* align with 2nd line (same as ellipsis) */
    left: 100%;       /* right side of cell */
    margin-left: 0;   /* IMPORTANT: no gap */
    z-index: 9999;
    background: #fff;
    border: 1px solid #ccc;
    box-shadow: 0 2px 10px rgba(0,0,0,.15);
    padding: 10px;
    min-width: 260px;
    max-width: 520px;
}


.mpcEllipsis {
    position: absolute;
    right: 0;
    top: 18px;
    cursor: pointer;
    background: #fff;
    padding-left: 6px;
    padding-right: 6px;  /* gives bigger hover area */
    height: 18px;
    line-height: 18px;
}


