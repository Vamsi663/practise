(function ($) {
  "use strict";

  function workflowButton() {
    return $("cq-siteadmin-admin-createworkflow");
  }

  function enableWorkflow() {
    workflowButton()
      .css("pointer-events", "")
      .css("opacity", "")
      .css("cursor", "")
      .removeAttr("title")
      .removeClass("is-disabled");
  }

  function disableWorkflow(owner) {
    workflowButton()
      .css("pointer-events", "none")
      .css("opacity", "0.4")
      .css("cursor", "not-allowed")
      .attr("title", "Page locked by " + owner)
      .addClass("is-disabled");
  }

  function getSelectedPath() {
    var $selected = $(".foundation-collection-item.is-selected").first();

    return $selected.data("foundationCollectionItemId") ||
           $selected.attr("data-foundation-collection-item-id") ||
           $selected.data("path") ||
           $selected.attr("data-path");
  }

  function checkLock() {
    setTimeout(function () {
      enableWorkflow();

      var path = getSelectedPath();
      console.log("selected path:", path);

      if (!path) {
        return;
      }

      $.getJSON(path + "/jcr:content.json").done(function (data) {
        console.log("lock owner:", data["jcr:lockOwner"]);

        if (data["jcr:lockOwner"]) {
          disableWorkflow(data["jcr:lockOwner"]);
        } else {
          enableWorkflow();
        }
      }).fail(function () {
        enableWorkflow();
      });

    }, 500);
  }

  $(document).on("click", ".foundation-collection-item", checkLock);
  $(document).on("foundation-selections-change", checkLock);
  $(document).on("foundation-collection-navigate", checkLock);

})(Granite.$);
