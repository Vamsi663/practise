(function ($) {
    "use strict";

    function enableWorkflow() {
        var $wf = $("cq-siteadmin-admin-createworkflow");

        $wf.css({
            "pointer-events": "",
            "opacity": "",
            "cursor": ""
        }).removeAttr("title");
    }

    function disableWorkflow(message) {
        var $wf = $("cq-siteadmin-admin-createworkflow");

        $wf.css({
            "pointer-events": "none",
            "opacity": "0.4",
            "cursor": "not-allowed"
        }).attr("title", message);
    }

    function checkWorkflowLock() {

        setTimeout(function () {

            enableWorkflow();

            var selectedPaths = [];

            $(".foundation-selections-item").each(function () {
                var path = $(this).data("foundationCollectionItemId")
                    || $(this).data("path");

                if (path) {
                    selectedPaths.push(path);
                }
            });

            if (selectedPaths.length === 0) {
                enableWorkflow();
                return;
            }

            var path = selectedPaths[0];

            $.getJSON(path + "/jcr:content.json")
                .done(function (data) {

                    if (data["jcr:lockOwner"]) {

                        disableWorkflow(
                            "Page locked by " +
                            data["jcr:lockOwner"] +
                            ". Please unlock before starting a workflow."
                        );

                    } else {

                        enableWorkflow();

                    }
                })
                .fail(function () {

                    enableWorkflow();

                });

        }, 300);
    }

    $(document).on("foundation-selections-change", checkWorkflowLock);

    $(document).on("click", ".foundation-collection-item", checkWorkflowLock);

})(Granite.$);
