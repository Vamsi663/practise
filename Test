(function ($, Granite) {
    "use strict";

    var lockCache = {}; // cache lock status per path

    // Pre-fetch lock status when a page is SELECTED (before menu opens)
    $(document).on("foundation-selections:change", function () {
        lockCache = {}; // clear old cache

        $(".foundation-selections-item").each(function () {
            var path = $(this).data("foundationCollectionItemId");
            if (!path) return;

            // Fetch and CACHE immediately on selection
            $.getJSON(path + "/jcr:content.json").done(function (data) {
                lockCache[path] = data["jcr:lockOwner"] || null;
                console.log("Cached lock for", path, ":", lockCache[path]);
            });
        });
    });

    // When menu opens - use cache, NO AJAX delay
    $(document).on("coral-overlay:open", function () {
        var checkId = Date.now();
        window._lastWorkflowCheckId = checkId;

        setTimeout(function () {
            if (window._lastWorkflowCheckId !== checkId) return;

            var $wf = $("a.cq-siteadmin-admin-createworkflow");
            if ($wf.length === 0) return;

            // Reset
            $wf.removeAttr("style").removeAttr("title");

            // Use cached value - no AJAX needed
            var isLocked = false;
            var lockOwner = "";

            Object.keys(lockCache).forEach(function (path) {
                if (lockCache[path]) {
                    isLocked = true;
                    lockOwner = lockCache[path];
                }
            });

            if (isLocked) {
                $wf.css({
                    "pointer-events": "none",
                    "opacity": "0.4",
                    "cursor": "not-allowed"
                }).attr("title",
                    "Locked by: " + lockOwner +
                    ". Please unlock before starting a workflow."
                );
            }

        }, 150);
    });

}(Granite.$, Granite));
