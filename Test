package com.barclays.uscb.core.models.impl;

import com.adobe.cq.wcm.core.components.models.Carousel;
import io.wcm.testing.mock.aem.junit5.AemContext;
import io.wcm.testing.mock.aem.junit5.AemContextExtension;
import org.apache.sling.api.resource.Resource;
import org.apache.sling.testing.mock.sling.ResourceResolverType;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;

import java.util.Collections;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.function.Function;

import static org.junit.jupiter.api.Assertions.*;

/**
 * Unit tests for USCBCarouselImpl.
 */
@ExtendWith(AemContextExtension.class)
class USCBCarouselImplTest {

    private final AemContext context = new AemContext(ResourceResolverType.JCR_MOCK);

    private Resource carouselResource;

    @BeforeEach
    void setUp() {
        context.addModelsForClasses(USCBCarouselImpl.class);
        context.create().page("/content/test-page");
        context.currentPage("/content/test-page");
    }

    /**
     * Creates the carousel resource, registers a stub Carousel adapter
     * (bypassing the broken resourceSuperType resolution in JCR_MOCK),
     * and adapts via the request since USCBCarouselImpl supports that path.
     */
    private USCBCarouselImpl createCarouselModel(Map<String, Object> props) {
        Map<String, Object> allProps = new HashMap<>(props);

        carouselResource = context.create().resource(
                "/content/test-page/jcr:content/carousel", allProps);

        context.currentResource(carouselResource);
        context.request().setResource(carouselResource);

        // Inline anonymous stub instead of a new class file.
        context.registerAdapter(Resource.class, Carousel.class,
                (Function<Resource, Carousel>) resource -> new Carousel() {
                    @Override
                    public boolean isAutoplay() { return false; }

                    @Override
                    public int getDelay() { return 0; }

                    @Override
                    public boolean isAutopauseDisabled() { return false; }

                    @Override
                    public List<?> getPanels() { return Collections.emptyList(); }

                    @Override
                    public String getBackgroundStyle() { return null; }

                    @Override
                    public String getAppliedCssClasses() { return null; }

                    @Override
                    public String getId() { return "stub-carousel"; }

                    @Override
                    public String getExportedType() { return null; }
                });

        return context.request().adaptTo(USCBCarouselImpl.class);
    }

    private Map<String, Object> props() {
        return new HashMap<>();
    }

    @Test
    void testGetLoop_ReturnsTrue() {
        Map<String, Object> props = props();
        props.put("loop", true);
        props.put("speed", 500);
        props.put("slides", 3);
        props.put("slidesTablet", 2);
        props.put("slidesMobile", 1);
        props.put("spacing", 10);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertTrue(model.getLoop());
    }

    @Test
    void testGetLoop_ReturnsFalse() {
        Map<String, Object> props = props();
        props.put("loop", false);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertFalse(model.getLoop());
    }

    @Test
    void testGetSpeed_WhenSlidesIsPositive() {
        Map<String, Object> props = props();
        props.put("slides", 3);
        props.put("speed", 700);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertEquals(700, model.getSpeed());
    }

    @Test
    void testGetSpeed_WhenSlidesIsZeroOrLess_ReturnsDefault400() {
        Map<String, Object> props = props();
        props.put("slides", 0);
        props.put("speed", 700);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertEquals(400, model.getSpeed());
    }

    @Test
    void testGetSlides_WhenZero_ReturnsDefault1() {
        Map<String, Object> props = props();
        props.put("slides", 0);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertEquals(1, model.getSlides());
    }

    @Test
    void testGetSlidesTablet_WhenZeroOrLess_ReturnsDefault1() {
        Map<String, Object> props = props();
        props.put("slidesTablet", 0);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertEquals(1, model.getSlidesTablet());
    }

    @Test
    void testGetSlidesMobile_WhenZeroOrLess_ReturnsDefault1() {
        Map<String, Object> props = props();
        props.put("slidesMobile", 0);

        USCBCarouselImpl model = createCarouselModel(props);

        assertNotNull(model);
        assertEquals(1, model.getSlidesMobile());
    }

    @Test
    void testGetInitialSlide_NoActiveItem_ReturnsZero() {
        USCBCarouselImpl model = createCarouselModel(props());

        assertNotNull(model);
        assertEquals(0, model.getInitialSlide());
    }

    @Test
    void testGetInitialSlide_WithActiveItem_ReturnsMatchingIndex() {
        Map<String, Object> props = props();
        props.put("activeItem", "item1");

        USCBCarouselImpl model = createCarouselModel(props);

        context.create().resource(carouselResource.getPath() + "/item0");
        context.create().resource(carouselResource.getPath() + "/item1");
        context.create().resource(carouselResource.getPath() + "/item2");

        context.request().setResource(carouselResource);
        model = context.request().adaptTo(USCBCarouselImpl.class);

        assertNotNull(model);
        assertEquals(1, model.getInitialSlide());
    }
}
