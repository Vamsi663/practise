function setWorkflowButtonDisabled(disabled, message) {
    var $workflow = $("cq-siteadmin-admin-createworkflow");

    if (disabled) {
        $workflow.css({
            "pointer-events": "none",
            "opacity": "0.4",
            "cursor": "not-allowed"
        }).attr("title", message || "Page is locked");
    } else {
        $workflow.css({
            "pointer-events": "",
            "opacity": "",
            "cursor": ""
        }).removeAttr("title");
    }
}

function checkSelectedPageLock() {
    setTimeout(function () {
        var selectedPaths = [];

        $(".foundation-selections-item").each(function () {
            selectedPaths.push(
                $(this).data("foundationCollectionItemId") ||
                $(this).data("path")
            );
        });

        if (selectedPaths.length === 0) {
            setWorkflowButtonDisabled(false);
            return;
        }

        var path = selectedPaths[0];

        $.getJSON(path + "/jcr:content.json").done(function (data) {
            if (data["jcr:lockOwner"]) {
                setWorkflowButtonDisabled(true, "Please unlock the page before starting workflow");
            } else {
                setWorkflowButtonDisabled(false);
            }
        }).fail(function () {
            setWorkflowButtonDisabled(false);
        });

    }, 300);
}

$(document).on("click", ".foundation-collection-item", checkSelectedPageLock);
$(document).on("foundation-selections-change", checkSelectedPageLock);
