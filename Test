_buildMpcCodeReferences = function (data) {
  var mpcCodes = (data.mpcCodes && data.mpcCodes instanceof Array) ? data.mpcCodes : [];

  function esc(s) {
    return (s == null) ? "" : String(s)
      .replace(/&/g, "&amp;").replace(/</g, "&lt;")
      .replace(/>/g, "&gt;").replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function link(code) {
    return "<a href='#' class='viewMpcCodeDetailsBtn mpcLink'>" + esc(code) + "</a>";
  }

  var allLinks = "";
  mpcCodes.forEach(function (c) { allLinks += link(c); });

  var visibleLinks = "";
  mpcCodes.slice(0, 2).forEach(function (c) { visibleLinks += link(c); });

  var hasMore = mpcCodes.length > 2;

  return ""
    + "<div class='mpcCell'>"
    + "  <div class='mpcVisible'>" + visibleLinks + "</div>"
    + (hasMore ? "  <span class='mpcEllipsis'>&hellip;</span>" : "")
    + (hasMore ? "  <div class='mpcTooltip'>" + allLinks + "</div>" : "")
    + "</div>";
};



.mpcCell { position: relative; width: 100%; }

.mpcVisible .mpcLink {
  display: block;        // ✅ one per line
  line-height: 18px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 16px;   // space for …
}

/* ellipsis at end of 2nd link line */
.mpcEllipsis {
  position: absolute;
  right: 0;
  top: 18px;             // ✅ line-height value (2nd line)
  cursor: pointer;
  background: #fff;
  padding-left: 6px;
}

/* tooltip on right */
.mpcTooltip {
  display: none;
  position: absolute;
  top: 0;
  left: 100%;
  margin-left: 10px;
  z-index: 9999;
  background: #fff;
  border: 1px solid #ccc;
  box-shadow: 0 2px 10px rgba(0,0,0,.15);
  padding: 10px;
  min-width: 280px;
  max-width: 520px;
}

.mpcTooltip .mpcLink {
  display: block;        // ✅ one per line in tooltip too
  line-height: 18px;
  margin-bottom: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* show tooltip only on ellipsis hover */
.mpcEllipsis:hover + .mpcTooltip,
.mpcTooltip:hover { display: block; }

