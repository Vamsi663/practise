// PAGE EDITOR
function pageEditorWorkflowCheck(e) {
    if (!Granite.author || !Granite.author.ContentFrame) return;
    var pagePath = Granite.author.ContentFrame.getContentPath();
    if (!pagePath) return;

    e.stopImmediatePropagation();
    e.preventDefault();

    checkLock(pagePath,
        function (owner) {
            showLockAlert(owner);
        },
        function () {
            // Temporarily detach, click, reattach
            $(document).off("click", ".js-editor-WorkflowStart-activator",
                pageEditorWorkflowCheck);
            $(".js-editor-WorkflowStart-activator")[0].click();
            setTimeout(function () {
                $(document).on("click", ".js-editor-WorkflowStart-activator",
                    pageEditorWorkflowCheck);
            }, 1000);
        }
    );
}

$(document).on("click", ".js-editor-WorkflowStart-activator",
    pageEditorWorkflowCheck);
