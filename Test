_buildMpcCodeReferences = function (data) {
  var mpcCodes = data.mpcCodes || [];

  function link(code) {
    return "<a href='#' class='viewMpcCodeDetailsBtn mpcLink'>" + code + "</a>";
  }

  if (!mpcCodes.length) {
    return "";
  }

  // IMPORTANT: use <br/> so links never get glued together (even if some CSS overrides display:block)
  var visibleMpc = mpcCodes.slice(0, 2).map(link).join("<br/>");
  var allMpc = mpcCodes.map(link).join("<br/>");
  var moreMpc = mpcCodes.length > 2;

  return ""
    + "<div class='mpcCell'>"
    + "  <div class='mpcVisible'>" + visibleMpc + "</div>"
    + (moreMpc
        ? "  <span class='mpcEllipsis' tabindex='0' aria-label='Show all MPC codes'>&hellip;"
          + "    <div class='mpcTooltip'>" + allMpc + "</div>"
          + "  </span>"
        : "")
    + "</div>";
};


/* MPC cell container */
.mpcCell {
  position: relative;
  width: 100%;
}

/* visible MPC links (two lines max) */
.mpcVisible .mpcLink {
  display: block;
  line-height: 18px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ellipsis sits RIGHT AFTER the 2nd link */
.mpcEllipsis {
  display: inline-block;
  margin-left: 6px;
  line-height: 18px;
  cursor: pointer;
  font-weight: bold;
  background: #fff;
  position: relative; /* anchor for tooltip */
  z-index: 2;
}

/* tooltip panel (hidden by default) */
.mpcTooltip {
  display: none;
  position: absolute;
  top: 0;          /* aligns with ellipsis */
  left: 100%;      /* right next to ellipsis */
  margin-left: 0;  /* no gap */
  z-index: 9999;
  background: #fff;
  border: 1px solid #ccc;
  box-shadow: 0 2px 10px rgba(0,0,0,.15);
  padding: 10px;
  min-width: 260px;
  max-width: 520px;
}

/* show tooltip ONLY when hovering/focusing ellipsis (and keep it open while hovering tooltip) */
.mpcEllipsis:hover .mpcTooltip,
.mpcEllipsis:focus .mpcTooltip,
.mpcTooltip:hover {
  display: block !important;
}

/* links inside tooltip */
.mpcTooltip .mpcLink {
  display: block;
  line-height: 18px;
  margin-bottom: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

