(function ($, Granite) {
    "use strict";

    // Reusable function to show lock alert
    function showLockAlert(lockOwner) {
        var ui = $(window).adaptTo("foundation-ui");
        if (ui) {
            ui.alert(
                "Workflow Blocked",
                "This page is locked by '" + lockOwner +
                "'. Please unlock before starting a workflow.",
                "error"
            );
        }
    }

    // Reusable function to check lock and show alert
    function checkLockAndAlert(path, callback) {
        $.getJSON(path + "/jcr:content.json").done(function (data) {
            if (data["jcr:lockOwner"]) {
                showLockAlert(data["jcr:lockOwner"]);
            } else {
                if (callback) callback();
            }
        }).fail(function () {
            if (callback) callback();
        });
    }

    // ==========================================
    // PAGE EDITOR
    // ==========================================
    function checkWorkflowIfLocked() {
        if (!Granite.author || !Granite.author.ContentFrame) return;
        var pagePath = Granite.author.ContentFrame.getContentPath();
        if (!pagePath) return;

        // Intercept workflow click in Page Editor
        $(document).off("click.workflowLock")
            .on("click.workflowLock", "[class*='WorkflowStart']", function (e) {
                e.stopImmediatePropagation();
                e.preventDefault();
                checkLockAndAlert(pagePath, function () {
                    // Not locked - proceed
                    $(this).off("click.workflowLock").trigger("click");
                }.bind(this));
            });
    }

    $(document).on("click", "#pageinfo-trigger", function () {
        setTimeout(checkWorkflowIfLocked, 300);
    });

    // ==========================================
    // SITES CONSOLE
    // ==========================================
    $(document).on("coral-overlay:open", function () {
        var checkId = Date.now();
        window._lastWorkflowCheckId = checkId;

        setTimeout(function () {
            if (window._lastWorkflowCheckId !== checkId) return;

            var $wf = $("a.cq-siteadmin-admin-createworkflow");
            if ($wf.length === 0) return;

            var selectedPaths = [];
            $(".foundation-selections-item").each(function () {
                var itemId = $(this).data("foundationCollectionItemId");
                if (itemId) selectedPaths.push(itemId);
            });

            if (selectedPaths.length === 0) return;

            // Remove old handler and add new one
            $wf.off("click.workflowLock")
               .on("click.workflowLock", function (e) {
                    e.stopImmediatePropagation();
                    e.preventDefault();

                    var path = selectedPaths[0];
                    $.getJSON(path + "/jcr:content.json").done(function (data) {
                        if (data["jcr:lockOwner"]) {
                            showLockAlert(data["jcr:lockOwner"]);
                        } else {
                            $wf.off("click.workflowLock")[0].click();
                        }
                    }).fail(function () {
                        $wf.off("click.workflowLock")[0].click();
                    });
                });

        }, 400);
    });

    // ==========================================
    // TIMELINE PANEL
    // ==========================================
    $(document).on("coral-columnview:activeitemchange click", function () {
        var checkId = Date.now();
        window._lastTimelineCheckId = checkId;

        setTimeout(function () {
            if (window._lastTimelineCheckId !== checkId) return;

            var $btn = $("button.cq-siteadmin-admin-createworkflow");
            if ($btn.length === 0) return;

            var selectedPaths = [];
            $(".foundation-selections-item").each(function () {
                var itemId = $(this).data("foundationCollectionItemId");
                if (itemId) selectedPaths.push(itemId);
            });

            if (selectedPaths.length === 0) return;

            $btn.off("click.workflowLock")
                .on("click.workflowLock", function (e) {
                    e.stopImmediatePropagation();
                    e.preventDefault();

                    var path = selectedPaths[0];
                    $.getJSON(path + "/jcr:content.json").done(function (data) {
                        if (data["jcr:lockOwner"]) {
                            showLockAlert(data["jcr:lockOwner"]);
                        } else {
                            $btn.off("click.workflowLock")[0].click();
                        }
                    }).fail(function () {
                        $btn.off("click.workflowLock")[0].click();
                    });
                });

        }, 400);
    });

    // ==========================================
    // WORKFLOW MODELS CONSOLE
    // ==========================================
    window._workflowLockChecked = false;

    $(document).on("click", function (e) {
        var $clicked = $(e.target).closest("button, [is='coral-button']");
        if ($clicked.length === 0) return;
        if ($clicked.text().trim() !== "Run") return;

        if (window._workflowLockChecked === true) {
            window._workflowLockChecked = false;
            return;
        }

        var payloadPath = $("input[name='payload']").val();
        if (!payloadPath) return;

        e.stopImmediatePropagation();
        e.preventDefault();

        $.getJSON(payloadPath + "/jcr:content.json")
            .done(function (data) {
                if (data["jcr:lockOwner"]) {
                    window._workflowLockChecked = false;
                    showLockAlert(data["jcr:lockOwner"]);
                } else {
                    window._workflowLockChecked = true;
                    setTimeout(function () {
                        $clicked[0].click();
                    }, 50);
                }
            })
            .fail(function () {
                window._workflowLockChecked = true;
                setTimeout(function () {
                    $clicked[0].click();
                }, 50);
            });
    });

}(Granite.$, Granite));
