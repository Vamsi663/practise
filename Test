(function ($, Granite) {
    "use strict";

    function disableWorkflowIfLocked() {
        var pagePath = Granite.author.ContentFrame.getContentPath();

        $.getJSON(pagePath + "/jcr:content.json").done(function (data) {
            if (data["jcr:lockOwner"]) {
                $("[class*='WorkflowStart']")
                    .closest("coral-button, button")
                    .attr("disabled", "disabled")
                    .addClass("is-disabled");
            }
        });
    }

    $(document).on("click", "[class*='PageInfo']", function () {
        setTimeout(disableWorkflowIfLocked, 300);
    });

// // // SITES CONSOLE
    $(document).on("click", function () {
        console.log("=== Click event fired ===");

        setTimeout(function () {
            console.log("=== Inside setTimeout ===");

            var $wf = $("a.cq-siteadmin-admin-createworkflow");
            console.log("Workflow element found:", $wf.length);

            if ($wf.length === 0) {
                console.log("STOP: Workflow element not in DOM yet");
                return;
            }

            var selectedPaths = [];
            $(".foundation-selections-item").each(function () {
                var itemId = $(this).data("foundationCollectionItemId");
                console.log("Found selected item:", itemId);
                if (itemId) selectedPaths.push(itemId);
            });

            console.log("Total selected paths:", selectedPaths.length, selectedPaths);

            if (selectedPaths.length === 0) {
                console.log("STOP: No selected paths found");
                return;
            }

            selectedPaths.forEach(function (path) {
                console.log("Checking lock for path:", path);
                $.getJSON(path + "/jcr:content.json")
                    .done(function (data) {
                        console.log("jcr:lockOwner:", data["jcr:lockOwner"]);
                        if (data["jcr:lockOwner"]) {
                            console.log("Page is LOCKED - disabling workflow");
                            $("a.cq-siteadmin-admin-createworkflow")
                                .css({
                                    "pointer-events": "none",
                                    "opacity": "0.4",
                                    "cursor": "not-allowed"
                                })
                                .attr("title",
                                    "Locked by '" + data["jcr:lockOwner"] +
                                    "'. Unlock before starting a workflow."
                                );
                            console.log("Workflow element disabled");
                        } else {
                            console.log("Page is NOT locked");
                        }
                    })
                    .fail(function (err) {
                        console.log("AJAX failed:", err.status, err.statusText);
                    });
            });

        }, 800);
    });
})(Granite.$, // Find siteadmin specific clientlibs
performance.getEntriesByType("resource")
    .filter(function(r) { 
        return r.name.indexOf("siteadmin") > -1; 
    })
    .map(function(r) { return r.name; });

