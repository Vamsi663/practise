(function ($, Granite) {
    "use strict";

    function disableWorkflowIfLocked() {
        var pagePath = Granite.author.ContentFrame.getContentPath();

        $.getJSON(pagePath + "/jcr:content.json").done(function (data) {
            if (data["jcr:lockOwner"]) {
                $("[class*='WorkflowStart']")
                    .closest("coral-button, button")
                    .attr("disabled", "disabled")
                    .addClass("is-disabled");
            }
        });
    }

    $(document).on("click", "[class*='PageInfo']", function () {
        setTimeout(disableWorkflowIfLocked, 300);
    });

// SITES CONSOLE
    $(document).on("coral-overlay:open foundation-contentloaded", function () {
        var $workflowAction = $("a.cq-siteadmin-admin-createworkflow");
        if ($workflowAction.length === 0) return;

        var selectedPaths = [];
        $(".foundation-selections-item").each(function () {
            selectedPaths.push($(this).data("foundationCollectionItemId"));
        });

        if (selectedPaths.length === 0) return;

        var lockedOwners = [];
        var checks = selectedPaths.map(function (path) {
            return $.getJSON(path + "/jcr:content.json").then(function (data) {
                if (data["jcr:lockOwner"]) {
                    lockedOwners.push(data["jcr:lockOwner"]);
                }
            });
        });

        $.when.apply($, checks).done(function () {
            if (lockedOwners.length > 0) {
                $workflowAction
                    .addClass("is-disabled")
                    .attr("aria-disabled", "true")
                    .css({ "pointer-events": "none", "opacity": "0.4" })
                    .attr("title", "Page locked by: " + lockedOwners.join(", "));
            }
        });
    });

    // Hard block click
    $(document).on("click", "a.cq-siteadmin-admin-createworkflow.is-disabled", function (e) {
        e.preventDefault();
        e.stopImmediatePropagation();
        var ui = $(window).adaptTo("foundation-ui");
        if (ui) {
            ui.alert("Workflow Blocked",
                "Page is locked. Please unlock before starting a workflow.",
                "error");
        }
    });

})(Granite.$, Granite);
