// Check if there's a form
$("coral-dialog form").length
$("coral-dialog form").attr("action")
$("coral-dialog form").attr("method")

// Check the Run button's parent structure
$("coral-dialog button").filter(function() {
    return $(this).text().trim() === "Run";
}).closest("form").attr("action")

// Find all click handlers on the Run button
var btn = $("coral-dialog button").filter(function() {
    return $(this).text().trim() === "Run";
})[0];
$._data(btn, "events");
