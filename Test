(function ($) {
    "use strict";

    function getWorkflowAction() {
        return $("cq-siteadmin-admin-createworkflow")
            .closest(".foundation-collection-action, coral-button, button, a");
    }

    function enableWorkflow() {
        var $btn = getWorkflowAction();

        $btn.removeClass("is-disabled disabled")
            .removeAttr("disabled")
            .removeAttr("aria-disabled")
            .removeAttr("title")
            .css({
                "pointer-events": "",
                "opacity": "",
                "cursor": ""
            });
    }

    function disableWorkflow(owner) {
        var $btn = getWorkflowAction();

        $btn.addClass("is-disabled")
            .attr("aria-disabled", "true")
            .attr("title", "Page locked by " + owner)
            .css({
                "pointer-events": "none",
                "opacity": "0.4",
                "cursor": "not-allowed"
            });
    }

    function getSelectedPath() {
        var $selected = $(".foundation-collection-item.is-selected").first();

        return $selected.attr("data-foundation-collection-item-id")
            || $selected.data("foundationCollectionItemId")
            || $selected.attr("data-path")
            || $selected.data("path");
    }

    function checkLock() {
        setTimeout(function () {
            enableWorkflow();

            var path = getSelectedPath();
            console.log("Selected path:", path);

            if (!path) {
                return;
            }

            $.getJSON(path + "/jcr:content.json").done(function (data) {
                console.log("Lock owner:", data["jcr:lockOwner"]);

                if (data["jcr:lockOwner"]) {
                    disableWorkflow(data["jcr:lockOwner"]);
                } else {
                    enableWorkflow();
                }
            });
        }, 500);
    }

    $(document).on("foundation-selections-change", checkLock);
    $(document).on("click", ".foundation-collection-item", checkLock);

})(Granite.$);
