/* container for MPC column */
.mpcCell {
    position: relative;
    width: 100%;
    max-width: 240px; /* keeps column narrow */
}

/* visible MPC links */
.mpcVisible .mpcLink {
    display: block;            /* one per line */
    line-height: 18px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-right: 16px;       /* space for ellipsis */
}

/* ellipsis after second link */
.mpcEllipsis {
    position: absolute;
    right: 0;
    top: 18px;                 /* aligns with 2nd line */
    cursor: pointer;
    background: #fff;
    padding-left: 6px;
    font-weight: bold;
}

/* tooltip panel */
.mpcTooltip {
    display: none;
    position: absolute;
    top: 0;
    left: 100%;                /* show on right side */
    margin-left: 10px;
    z-index: 9999;
    background: #fff;
    border: 1px solid #ccc;
    box-shadow: 0 2px 10px rgba(0,0,0,.15);
    padding: 10px;
    min-width: 260px;
    max-width: 520px;
}

/* links inside tooltip */
.mpcTooltip .mpcLink {
    display: block;
    line-height: 18px;
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* keep tooltip visible when moving cursor */
.mpcCell:hover .mpcTooltip {
    display: block;
}

/* optional: highlight ellipsis on hover */
.mpcEllipsis:hover {
    color: #0070d2;
}

/* ensure column does not stretch table */
#offerProductTable td,
#offerProductTable th {
    vertical-align: top;
}
