(function ($) {
  "use strict";

  var requestId = 0;

  function getWorkflowButton() {
    return $("cq-siteadmin-admin-createworkflow");
  }

  function enableWorkflow() {
    getWorkflowButton()
      .removeAttr("style")
      .removeAttr("title")
      .removeAttr("disabled")
      .removeAttr("aria-disabled")
      .removeClass("is-disabled disabled");
  }

  function disableWorkflow(owner) {
    getWorkflowButton()
      .css({
        "pointer-events": "none",
        "opacity": "0.4",
        "cursor": "not-allowed"
      })
      .attr("title", "Page locked by " + owner)
      .attr("aria-disabled", "true")
      .addClass("is-disabled");
  }

  function getSelectedPath() {
    var $item = $(".foundation-collection-item.is-selected").last();

    return $item.attr("data-foundation-collection-item-id") ||
           $item.data("foundationCollectionItemId") ||
           $item.attr("data-path") ||
           $item.data("path");
  }

  function checkLock() {
    var currentRequest = ++requestId;

    setTimeout(function () {
      var path = getSelectedPath();

      console.log("Selected path:", path);

      enableWorkflow();

      if (!path) {
        return;
      }

      $.getJSON(path + "/jcr:content.json").done(function (data) {

        // ignore old ajax response
        if (currentRequest !== requestId) {
          return;
        }

        console.log("Lock owner:", data["jcr:lockOwner"]);

        if (data["jcr:lockOwner"]) {
          disableWorkflow(data["jcr:lockOwner"]);
        } else {
          enableWorkflow();
        }
      }).fail(function () {
        if (currentRequest === requestId) {
          enableWorkflow();
        }
      });

    }, 300);
  }

  $(document).on("foundation-selections-change click", ".foundation-collection-item", checkLock);
  $(document).on("foundation-selections-change", checkLock);

})(Granite.$);
