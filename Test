// WORKFLOW MODELS CONSOLE
$(document).on("click", function (e) {
    var $clicked = $(e.target).closest("button, [is='coral-button']");
    if ($clicked.length === 0) return;
    if ($clicked.text().trim() !== "Run") return;

    var $form = $("coral-dialog form");
    if ($form.length === 0) return;

    var payloadPath = $("input[name='payload']").val();
    if (!payloadPath) return;

    e.stopImmediatePropagation();
    e.preventDefault();

    $.getJSON(payloadPath + "/jcr:content.json")
        .done(function (data) {
            if (data["jcr:lockOwner"]) {
                var ui = $(window).adaptTo("foundation-ui");
                if (ui) {
                    ui.alert(
                        "Workflow Blocked",
                        "Page is locked by '" + data["jcr:lockOwner"] +
                        "'. Please unlock before running a workflow.",
                        "error"
                    );
                }
            } else {
                // Submit via AJAX to avoid page navigation
                $.ajax({
                    url: $form.attr("action"),
                    method: "POST",
                    data: $form.serialize(),
                    success: function () {
                        // Close dialog and show success
                        $("coral-dialog")[0].hide();
                        var ui = $(window).adaptTo("foundation-ui");
                        if (ui) {
                            ui.notify("success", "Workflow started successfully.");
                        }
                    },
                    error: function (err) {
                        var ui = $(window).adaptTo("foundation-ui");
                        if (ui) {
                            ui.alert("Error", "Failed to start workflow: " + err.statusText, "error");
                        }
                    }
                });
            }
        })
        .fail(function () {
            $.ajax({
                url: $form.attr("action"),
                method: "POST",
                data: $form.serialize(),
                success: function () {
                    $("coral-dialog")[0].hide();
                    var ui = $(window).adaptTo("foundation-ui");
                    if (ui) {
                        ui.notify("success", "Workflow started successfully.");
                    }
                }
            });
        });
});
