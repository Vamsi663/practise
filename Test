window._workflowLockChecked = false;

$(document).on("click", function (e) {
    var $clicked = $(e.target).closest("button, [is='coral-button']");
    if ($clicked.length === 0) return;
    if ($clicked.text().trim() !== "Run") return;

    // If already approved - let through and reset flag
    if (window._workflowLockChecked === true) {
        window._workflowLockChecked = false;
        return;
    }

    var payloadPath = $("input[name='payload']").val();
    if (!payloadPath) return;

    // Always block first
    e.stopImmediatePropagation();
    e.preventDefault();

    $.getJSON(payloadPath + "/jcr:content.json")
        .done(function (data) {
            if (data["jcr:lockOwner"]) {
                // LOCKED - block and show error
                window._workflowLockChecked = false;
                var ui = $(window).adaptTo("foundation-ui");
                if (ui) {
                    ui.alert(
                        "Workflow Blocked",
                        "Page is locked by '" + data["jcr:lockOwner"] +
                        "'. Please unlock before running a workflow.",
                        "error"
                    );
                }
            } else {
                // NOT locked - set flag and re-click
                window._workflowLockChecked = true;
                setTimeout(function () {
                    $clicked[0].click();
                }, 50);
            }
        })
        .fail(function () {
            // Can't determine lock - allow through
            window._workflowLockChecked = true;
            setTimeout(function () {
                $clicked[0].click();
            }, 50);
        });
});
