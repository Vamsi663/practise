// Monitor ALL events on document
var events = ["click", "mouseup", "foundation-selections:change", 
              "foundation-collection:change", "coral-collection:change",
              "foundation-contentloaded", "coral-columnview:change",
              "coral-columnview:activeitemchange"];

events.forEach(function(evt) {
    $(document).on(evt, function() {
        console.log("EVENT FIRED:", evt);
    });
});
