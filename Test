.mpcEllipsis {
  display:inline;
  margin-left:4px;
  cursor:pointer;
  font-weight:normal;
}

.mpcTooltip {
  display:none;
  position:absolute;
  top:0;
  left:100%;
  margin-left:4px;
  background:#fff;
  border:1px solid #ccc;
  box-shadow:0 2px 10px rgba(0,0,0,.15);
  padding:6px;
  min-width:220px;
  z-index:9999;
}

.mpcTooltip .mpcLink {
  display:block;
  font-weight:normal;
  line-height:16px;
  margin-bottom:2px;
}

.mpcEllipsis:hover .mpcTooltip,
.mpcEllipsis:focus .mpcTooltip,
.mpcTooltip:hover {
  display:block;
}
