.mpcEllipsis {
  position: absolute;
  top: 18px;              /* align with 2nd line */
  left: auto;
  right: auto;
  margin-left: 4px;       /* keeps it next to text */

  font-size: 16px;        /* make it visible */
  font-weight: bold;

  cursor: pointer;
  background: #fff;
  padding: 0 4px;
}


.mpcVisible .mpcLink {
  display: block;
  line-height: 18px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 30px;   /* increased space */
}



