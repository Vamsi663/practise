_buildMpcCodeReferences = function (data) {
  var mpcCodes = data.mpcCodes || [];

  function link(code) {
    return "<a href='#' class='viewMpcCodeDetailsBtn mpcLink'>" + code + "</a>";
  }

  if (!mpcCodes.length) {
    return "";
  }

  var first = mpcCodes[0] ? link(mpcCodes[0]) : "";
  var second = mpcCodes[1] ? link(mpcCodes[1]) : "";
  var allMpc = mpcCodes.map(link).join("");

  var moreMpc = mpcCodes.length > 2;

  // 2 visible lines (each on its own line)
  var visibleHtml =
    "<div class='mpcLine mpcLine1'>" + first + "</div>" +
    "<div class='mpcLine mpcLine2'>" +
      second +
      (moreMpc ? "<span class='mpcEllipsis' tabindex='0' aria-label='Show all MPC codes'>&hellip;</span>" : "") +
    "</div>";

  return ""
    + "<div class='mpcCell'>"
    +   "<div class='mpcVisible'>" + visibleHtml + "</div>"
    +   (moreMpc ? "<div class='mpcTooltip'>" + allMpc + "</div>" : "")
    + "</div>";
};


/* Make 2nd line hold link + ellipsis together */
.mpcLine2{
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

/* Ellipsis should NOT be absolute anymore */
.mpcEllipsis{
  position: static;     /* overrides absolute */
  top: auto;
  right: auto;
  padding: 0;
  background: transparent;
}

.mpcLine2 .mpcLink{ flex: 0 1 auto; }
