// WORKFLOW MODELS CONSOLE - Validate on Run
$(document).on("click", function (e) {
    var $clicked = $(e.target).closest("button, [is='coral-button']");
    if ($clicked.length === 0) return;
    if ($clicked.text().trim() !== "Run") return;

    var payloadPath = $("input[name='payload']").val();
    if (!payloadPath) return;

    e.stopImmediatePropagation();
    e.preventDefault();

    $.getJSON(payloadPath + "/jcr:content.json").done(function (data) {
        if (data["jcr:lockOwner"]) {
            var ui = $(window).adaptTo("foundation-ui");
            if (ui) {
                ui.alert(
                    "Workflow Blocked",
                    "Page is locked by '" + data["jcr:lockOwner"] +
                    "'. Please unlock before running a workflow.",
                    "error"
                );
            }
        } else {
            // Not locked - proceed with original Run action
            $clicked.off("click").trigger("click");
        }
    }).fail(function () {
        // Path invalid or not a page - let it proceed
        $clicked.off("click").trigger("click");
    });
});
