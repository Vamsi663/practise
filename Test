function checkAndDisableWorkflow() {
        var $wf = $("a.cq-siteadmin-admin-createworkflow");
        if ($wf.length === 0) return;

        // ALWAYS reset first
        $wf.removeAttr("style").removeAttr("title");

        var selectedPaths = [];
        $(".foundation-selections-item").each(function () {
            var itemId = $(this).data("foundationCollectionItemId");
            if (itemId) selectedPaths.push(itemId);
        });

        if (selectedPaths.length === 0) return;

        selectedPaths.forEach(function (path) {
            $.getJSON(path + "/jcr:content.json").done(function (data) {
                console.log("Path:", path, "LockOwner:", data["jcr:lockOwner"]);
                if (data["jcr:lockOwner"]) {
                    $("a.cq-siteadmin-admin-createworkflow")
                        .css({
                            "pointer-events": "none",
                            "opacity": "0.4",
                            "cursor": "not-allowed"
                        })
                        .attr("title",
                            "Locked by: " + data["jcr:lockOwner"] +
                            ". Please unlock before starting a workflow."
                        );
                }
            });
        });
    }

    $(document).on("coral-overlay:open", function () {
        setTimeout(checkAndDisableWorkflow, 300);
    });

    $(document).on("click", function () {
        setTimeout(checkAndDisableWorkflow, 800);
    });
