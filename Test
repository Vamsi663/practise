// PAGE EDITOR
$(document).on("click", ".js-editor-WorkflowStart-activator", function (e) {
    if (!Granite.author || !Granite.author.ContentFrame) return;
    var pagePath = Granite.author.ContentFrame.getContentPath();
    if (!pagePath) return;

    e.stopImmediatePropagation();
    e.preventDefault();

    $.getJSON(pagePath + "/jcr:content.json").done(function (data) {
        if (data["jcr:lockOwner"]) {
            showLockAlert(data["jcr:lockOwner"]);
        } else {
            // Temporarily remove handler, click, restore
            $(document).off("click", ".js-editor-WorkflowStart-activator");
            $(".js-editor-WorkflowStart-activator")[0].click();
            setTimeout(function () {
                attachPageEditorInterceptor();
            }, 500);
        }
    }).fail(function () {
        $(document).off("click", ".js-editor-WorkflowStart-activator");
        $(".js-editor-WorkflowStart-activator")[0].click();
        setTimeout(attachPageEditorInterceptor, 500);
    });
});

function attachPageEditorInterceptor() {
    $(document).on("click", ".js-editor-WorkflowStart-activator", pageEditorWorkflowCheck);
}

function pageEditorWorkflowCheck(e) {
    if (!Granite.author || !Granite.author.ContentFrame) return;
    var pagePath = Granite.author.ContentFrame.getContentPath();
    if (!pagePath) return;

    e.stopImmediatePropagation();
    e.preventDefault();

    $.getJSON(pagePath + "/jcr:content.json").done(function (data) {
        if (data["jcr:lockOwner"]) {
            showLockAlert(data["jcr:lockOwner"]);
        } else {
            $(document).off("click", ".js-editor-WorkflowStart-activator");
            $(".js-editor-WorkflowStart-activator")[0].click();
            setTimeout(attachPageEditorInterceptor, 500);
        }
    }).fail(function () {
        $(document).off("click", ".js-editor-WorkflowStart-activator");
        $(".js-editor-WorkflowStart-activator")[0].click();
        setTimeout(attachPageEditorInterceptor, 500);
    });
}
