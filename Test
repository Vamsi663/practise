@BeforeEach
void setUp() throws Exception {

    context.create().resource("/content/carousel");
    context.create().resource("/content/carousel/item1");
    context.create().resource("/content/carousel/item2");
    context.create().resource("/content/carousel/item3");

    model = new USCBCarouselImpl();

    Resource resource = context.resourceResolver().getResource("/content/carousel");
    setField(model, "resource", resource);
}




@Test
void testGetLoopTrue() throws Exception {
    setField(model, "loop", true);
    assertTrue(model.getLoop());
}

@Test
void testGetSpeedDefault() throws Exception {
    setField(model, "slides", 0);
    setField(model, "speed", 900);
    assertEquals(400, model.getSpeed());
}

@Test
void testGetSlidesDefault() throws Exception {
    setField(model, "slides", 0);
    assertEquals(1, model.getSlides());
}

@Test
void testGetInitialSlideMiddleItem() throws Exception {
    setField(model, "activeItem", "item2");
    assertEquals(1, model.getInitialSlide());
}
