_buildMpcCodeReferences = function (data) {

  var mpcCodes = data.mpcCodes || [];

  function link(code) {
    return "<a href='#' class='viewMpcCodeDetailsBtn mpcLink'>" + code + "</a>";
  }

  if (!mpcCodes.length) {
    return "";
  }

  var allMpc = mpcCodes.map(link).join("");
  var moreMpc = mpcCodes.length > 2;

  var visibleMpc = "";

  // First line
  visibleMpc += "<div class='mpcLine'>" + link(mpcCodes[0]) + "</div>";

  // Second line
  if (mpcCodes.length > 1) {

    visibleMpc += "<div class='mpcLine'>" + link(mpcCodes[1]);

    if (moreMpc) {
      visibleMpc +=
        "<span class='mpcMore' tabindex='0' aria-label='Show all MPC codes'>&hellip;" +
          "<span class='mpcTooltip'>" + allMpc + "</span>" +
        "</span>";
    }

    visibleMpc += "</div>";
  }

  return (
    "<div class='mpcCell'>" +
      "<div class='mpcVisible'>" + visibleMpc + "</div>" +
    "</div>"
  );
};

